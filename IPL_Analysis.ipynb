# ============================
# IPL Data Analysis (Corrected)
# ============================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset
df = pd.read_csv("/content/IPL.csv", low_memory=False)

# Convert date
df["date"] = pd.to_datetime(df["date"])

# ---------------------------------
# Create Match-Level Dataset
# ---------------------------------
matches = df.groupby("match_id", as_index=False).first()

print("Ball Records :", len(df))
print("Matches :", len(matches))

# ---------------------------------
# 1. Top 10 Most Successful Teams
# ---------------------------------

top_teams = matches["match_won_by"].value_counts().head(10)

plt.figure(figsize=(10,6))
sns.barplot(
    x=top_teams.values,
    y=top_teams.index,
    hue=top_teams.index,
    palette="magma",
    legend=False
)

plt.title("Top 10 Teams by Match Wins")
plt.xlabel("Matches Won")
plt.ylabel("Team")
plt.show()

# ---------------------------------
# 2. Top 10 Run Scorers
# ---------------------------------

top_batsmen = (
    df.groupby("batter")["batter_runs"]
      .sum()
      .sort_values(ascending=False)
      .head(10)
)

plt.figure(figsize=(10,6))
sns.barplot(
    x=top_batsmen.values,
    y=top_batsmen.index,
    hue=top_batsmen.index,
    palette="Oranges",
    legend=False
)

plt.title("Top 10 Run Scorers")
plt.xlabel("Runs")
plt.ylabel("Batter")
plt.show()

# ---------------------------------
# 3. Top 10 Wicket Takers
# ---------------------------------

top_bowlers = (
    df.groupby("bowler")["bowler_wicket"]
      .sum()
      .sort_values(ascending=False)
      .head(10)
)

plt.figure(figsize=(10,6))
sns.barplot(
    x=top_bowlers.values,
    y=top_bowlers.index,
    hue=top_bowlers.index,
    palette="Greens",
    legend=False
)

plt.title("Top 10 Wicket Takers")
plt.xlabel("Wickets")
plt.ylabel("Bowler")
plt.show()

# ---------------------------------
# 4. Toss Decision Analysis
# ---------------------------------

toss = matches["toss_decision"].value_counts()

plt.figure(figsize=(6,6))
plt.pie(
    toss.values,
    labels=toss.index,
    autopct="%1.1f%%",
    startangle=90
)

plt.title("Toss Decisions")
plt.show()

# ---------------------------------
# 5. Toss Winner vs Match Winner
# ---------------------------------

toss_win = matches[matches["toss_winner"] == matches["match_won_by"]]

print("Matches:", len(matches))
print("Won after winning toss:", len(toss_win))
print("Percentage:", round(len(toss_win)/len(matches)*100,2), "%")

# ---------------------------------
# 6. Top Players of the Match
# ---------------------------------

top_pom = matches["player_of_match"].value_counts().head(10)

plt.figure(figsize=(10,6))
sns.barplot(
    x=top_pom.values,
    y=top_pom.index,
    hue=top_pom.index,
    palette="viridis",
    legend=False
)

plt.title("Top Player of the Match Winners")
plt.xlabel("Awards")
plt.ylabel("Player")
plt.show()

# ---------------------------------
# 7. Most Sixes
# ---------------------------------

sixes = (
    df[df["runs_batter"] == 6]
      .groupby("batter")
      .size()
      .sort_values(ascending=False)
      .head(10)
)

plt.figure(figsize=(10,6))
sns.barplot(
    x=sixes.values,
    y=sixes.index,
    hue=sixes.index,
    palette="Reds",
    legend=False
)

plt.title("Most Sixes")
plt.xlabel("Sixes")
plt.ylabel("Batter")
plt.show()

# ---------------------------------
# 8. Highest Team Scores
# ---------------------------------

team_scores = (
    df.groupby(["match_id","innings","batting_team"])["runs_total"]
      .sum()
      .reset_index()
      .sort_values("runs_total", ascending=False)
)

print("\nTop 10 Highest Team Scores")
print(team_scores.head(10))
