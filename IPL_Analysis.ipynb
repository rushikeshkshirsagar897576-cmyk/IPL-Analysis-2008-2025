import matplotlib.pyplot as plt
import seaborn as sns

# Kyunki aapke data mein column ka naam 'match_won_by' hai
col_name = 'match_won_by'

if col_name in df_full.columns:
    plt.figure(figsize=(12,8))

    # Sabse zyada jeetne wali top 10 teams
    top_10 = df_full[col_name].value_counts().head(10)

    # Graph banana
    sns.barplot(x=top_10.values, y=top_10.index, palette='magma')

    plt.title('IPL: Most Successful Teams (2008-2025)', fontsize=15)
    plt.xlabel('Number of Wins (Ball Data Count)', fontsize=12)
    plt.ylabel('Teams', fontsize=12)
    plt.show()
else:
    print(f"Error: '{col_name}' column nahi mila. Check karein.")
     
