import pandas as pd
import os

# Ye code apne aap aapki 108MB wali file dhoond lega
files = [f for f in os.listdir('/content') if f.endswith('.csv')]

if files:
    file_path = f'/content/{files[0]}'
    # Badi file ke liye low_memory=False zaruri hai
    df_full = pd.read_csv(file_path, low_memory=False)
    print(f"Mubarak ho! {files[0]} successfully load ho gaya.")
    print("Ab hum graph bana sakte hain.")
else:
    print("Error: File nahi mili. Folder icon se upload check karein.")
     
