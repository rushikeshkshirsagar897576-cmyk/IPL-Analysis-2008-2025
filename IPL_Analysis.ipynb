import pandas as pd

data = {
    "season": [2019, 2019, 2019, 2020, 2020, 2020],
    "team1": ["MI", "CSK", "RCB", "MI", "CSK", "RCB"],
    "team2": ["RCB", "MI", "CSK", "CSK", "RCB", "MI"],
    "winner": ["MI", "CSK", "RCB", "CSK", "CSK", "MI"],
    "toss_winner": ["MI", "MI", "RCB", "CSK", "RCB", "MI"]
}

df = pd.DataFrame(data)

