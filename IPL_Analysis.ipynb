# Sabse zyada runs banane wale Top 10 batters (2008-2025)
top_batsmen = df_full.groupby('batter')['batter_runs'].sum().sort_values(ascending=False).head(10)

plt.figure(figsize=(12,6))
top_batsmen.plot(kind='bar', color='orange')

plt.title('IPL: All-Time Top 10 Run Scorers (2008-2025)', fontsize=15)
plt.ylabel('Total Runs')
plt.xlabel('Batter Name')
plt.xticks(rotation=45)
plt.show()
     


# Toss decision ka analysis
toss_choice = df_full['toss_decision'].value_counts()

plt.figure(figsize=(7,7))
plt.pie(toss_choice, labels=toss_choice.index, autopct='%1.1f%%', colors=['skyblue', 'lightgreen'], startangle=90)
plt.title('IPL Toss Decisions: Bat vs Field (2008-2025)')
plt.show()
     


